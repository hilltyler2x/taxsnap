# ─────────────────────────────────────────
# DATABASE (Supabase)
# Get from: supabase.com → project → Settings → Database → Connection string (URI)
# ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# ─────────────────────────────────────────
# CLERK AUTH
# dashboard.clerk.com → your app → API Keys
# ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."

# ─────────────────────────────────────────
# GOOGLE OAUTH + GMAIL API
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Enable: Gmail API + People API
# Redirect URI: https://YOUR-DOMAIN/api/auth/callback/google
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─────────────────────────────────────────
# MICROSOFT OAUTH + OUTLOOK
# portal.azure.com → App registrations → New registration
# Redirect URI: https://YOUR-DOMAIN/api/auth/callback/azure-ad
# API permissions: Mail.Read, offline_access, openid, profile, email
# ─────────────────────────────────────────
AZURE_AD_CLIENT_ID="your-azure-app-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-client-secret"
AZURE_AD_TENANT_ID="common"

# ─────────────────────────────────────────
# STRIPE PAYMENTS
# dashboard.stripe.com → Developers → API keys
# Create 5 products in Stripe and paste each Price ID below
# ─────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_ANNUAL_PRICE_ID="price_..."
STRIPE_BUSINESS_MONTHLY_PRICE_ID="price_..."
STRIPE_BUSINESS_ANNUAL_PRICE_ID="price_..."
STRIPE_LIFETIME_PRICE_ID="price_..."

# Also expose price IDs to the frontend
NEXT_PUBLIC_STRIPE_PRO_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRO_ANNUAL="price_..."
NEXT_PUBLIC_STRIPE_BUSINESS_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_BUSINESS_ANNUAL="price_..."
NEXT_PUBLIC_STRIPE_LIFETIME="price_..."

# ─────────────────────────────────────────
# ANTHROPIC — AI receipt scanning
# console.anthropic.com → API Keys
# ─────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─────────────────────────────────────────
# OWNER ACCESS — your free admin account
# Set OWNER_EMAIL to your real email — that account auto-gets owner access on login
# ─────────────────────────────────────────
OWNER_EMAIL="your@email.com"
